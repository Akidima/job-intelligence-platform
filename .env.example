# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_intelligence
REDIS_URL=redis://localhost:6379/0

# Scraping
SCRAPE_DELAY_MIN=1.0
SCRAPE_DELAY_MAX=3.0
MAX_CONCURRENT_REQUESTS=5
USER_AGENT_ROTATION=true

# API Keys (optional)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
REMOTIVE_API_KEY=

# Welcome to the Jungle (optional, for reliable scraping)
# Open welcometothejungle.com/en/jobs, then in browser DevTools > Network find a
# request to *.algolia.net and copy the x-algolia-application-id and
# x-algolia-api-key (the search-only key). Without these, the scraper uses
# WTTJ's public REST API on a best-effort basis.
WTTJ_ALGOLIA_APP_ID=
WTTJ_ALGOLIA_API_KEY=
WTTJ_ALGOLIA_INDEX=wttj_jobs_production_en

# Optional LLM-assisted skill extraction (OpenAI-compatible endpoint).
# Off by default -> uses the fast regex extractor. To enable, e.g. local Ollama:
#   1) ollama pull qwen3 && ollama serve
#   2) set the three vars below
# Works with any OpenAI-compatible backend (Ollama, DeepSeek, Groq, OpenAI) by
# changing LLM_BASE_URL / LLM_MODEL / LLM_API_KEY.
LLM_SKILL_EXTRACTION=false
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3
LLM_API_KEY=

# Notifications (optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=

# App
APP_ENV=development
LOG_LEVEL=INFO
DATA_DIR=./data
